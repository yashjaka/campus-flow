{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node scripts/preinstall.cjs",
    "dev": "pnpm --filter \"@workspace/campusflow\" run dev",
    "build": "pnpm --filter \"@workspace/campusflow\" run build",
    "preview": "pnpm --filter \"@workspace/campusflow\" run preview",
    "lint": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\" --ignore-path .gitignore",
    "typecheck": "pnpm --filter \"@workspace/campusflow\" run typecheck"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  }
}
