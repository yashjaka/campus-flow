# CampusFlow Environment Variables Configuration Template
# Copy this file to .env in your root directory and customize the values.

# Port for the backend API server (defaults to 5000)
PORT=5000

# JSON Web Token secret key for signing user sessions
JWT_SECRET=your_jwt_secret_key_here

# Mode of deployment (development / production)
NODE_ENV=development

# Logging level (trace / debug / info / warn / error / fatal)
LOG_LEVEL=info

